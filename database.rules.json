{
  "rules": {
    ".read": false,
    ".write": false,
    "briefs": {
      "$token": {
        ".read": true,
        "subs": {
          ".write": true,
          "$sid": {
            ".validate": "!newData.exists() || newData.hasChild('sub')",
            "sub": {
              ".validate": "newData.hasChild('endpoint')",
              "endpoint": { ".validate": "newData.isString() && newData.val().length <= 1024" },
              "expirationTime": { ".validate": "newData.isNumber()" },
              "keys": {
                "p256dh": { ".validate": "newData.isString() && newData.val().length <= 256" },
                "auth": { ".validate": "newData.isString() && newData.val().length <= 256" },
                "$other": { ".validate": false }
              },
              "$other": { ".validate": false }
            },
            "ua": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "at": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "msg_outbox": {
          ".write": true,
          "$oid": {
            ".validate": "!newData.exists() || newData.hasChild('chatID')",
            "chatID": { ".validate": "newData.isString() && newData.val().length <= 512" },
            "text": { ".validate": "newData.isString() && newData.val().length <= 20000" },
            "action": { ".validate": "newData.isString() && newData.val().length <= 32" },
            "at": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "flags": {
          ".write": true,
          "$fid": {
            ".validate": "!newData.exists() || newData.hasChildren()",
            "pin": { ".validate": "newData.isBoolean()" },
            "snooze": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "settings": {
          ".write": true,
          "group_threads": { ".validate": "newData.isBoolean()" },
          "$other": { ".validate": false }
        }
      }
    }
  }
}
